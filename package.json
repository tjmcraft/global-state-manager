{
  "name": "@tjmc/global-state-manager",
  "version": "0.0.52",
  "description": "Global State Manager for React",
  "scripts": {
    "build": "rimraf dist && tsup",
    "typescript": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run",
    "test:store": "vitest run test/store",
    "test:hooks": "vitest run test/hooks",
    "test:hoc": "vitest run test/hoc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tjmcraft/global-state-manager.git"
  },
  "keywords": [
    "React",
    "Global",
    "State"
  ],
  "author": "MakAndJo",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/tjmcraft/global-state-manager/issues"
  },
  "homepage": "https://github.com/tjmcraft/global-state-manager#readme",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^15.0.7",
    "@types/node": "^20.10.3",
    "@types/react": "^18.2.41",
    "@types/react-dom": "^18.2.17",
    "jsdom": "^24.1.3",
    "react": "^18.2.0",
    "react-dom": "^18.3.1",
    "rimraf": "^5.0.5",
    "tslib": "^2.6.2",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2",
    "vitest": "^2.1.9"
  },
  "peerDependencies": {
    "react": ">=18.0",
    "react-dom": ">=18.0",
    "react-native": ">=0.71"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  },
  "module": "dist/global-state-manager.legacy-esm.js",
  "main": "dist/global-state-manager.cjs",
  "types": "dist/global-state-manager.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./tsconfig.json": "./tsconfig.json",
    ".": {
      "types": "./dist/global-state-manager.d.ts",
      "import": "./dist/global-state-manager.mjs",
      "default": "./dist/global-state-manager.cjs"
    }
  },
  "sideEffects": false
}
